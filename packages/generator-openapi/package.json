{
  "name": "@dese-mcp/generator-openapi",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@dese-mcp/generator-core": "workspace:*",
    "@dese-mcp/mcp-core": "workspace:*",
    "@dese-mcp/shared": "workspace:*",
    "@apidevtools/swagger-parser": "^10.1.1",
    "openapi-types": "^12.1.3"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
